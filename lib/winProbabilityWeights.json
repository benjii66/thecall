{
    "meta": {
        "version": "3.0",
        "description": "Heuristic-based win probability weights for LoL match analysis (Season 16 tuned)",
        "philosophy": "Broadcast-ready: objectives/structures > kills, visible swing moments, always comeback room (no early 99%)"
    },
    "timeScaling": {
        "early": {
            "minutes": [
                0,
                14
            ],
            "multiplier": 0.92
        },
        "mid": {
            "minutes": [
                14,
                25
            ],
            "multiplier": 1.00
        },
        "late": {
            "minutes": [
                25,
                60
            ],
            "multiplier": 1.10
        }
    },
    "kills": {
        "kill": 1.05,
        "death": -1.15,
        "assist": 0.50,
        "shutdownTaken": 3.0,
        "shutdownGiven": -3.2,
        "firstBloodBonus": 0.9,
        "doubleKillBonus": 0.6,
        "tripleKillBonus": 1.3,
        "quadraKillBonus": 2.1,
        "pentaKillBonus": 3.2,
        "ace": 3.8
    },
    "objectives": {
        "tower": {
            "outer": 3.4,
            "inner": 4.1,
            "inhibitor": 5.8
        },
        "turretPlate": 0.65,
        "firstTurretBonus": 2.0,
        "herald": 2.8,
        "dragon": {
            "first": 2.0,
            "second": 2.8,
            "third": 3.5,
            "soul": 9.2
        },
        "baron": 10.2,
        "elder": 13.5,
        "voidGrub": 1.6,
        "inhibitorDestroyed": 6.5,
        "steal": {
            "dragon": 2.4,
            "baron": 4.8,
            "elder": 6.0,
            "herald": 1.8,
            "voidGrub": 1.2
        }
    },
    "economy": {
        "goldDiffPer1000": 1.3
    },
    "limits": {
        "maxPositiveScore": 26,
        "maxNegativeScore": -26,
        "softCapStart": 16,
        "softCapMultiplier": 0.55
    },
    "smoothing": {
        "windowMinutes": 2,
        "method": "moving-average"
    }
}