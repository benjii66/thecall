generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                  @id @default(cuid())
  name                    String?
  email                   String?                 @unique
  emailVerified           DateTime?
  image                   String?
  riotPuuid               String?                 @unique
  riotGameName            String?
  riotTagLine             String?
  riotRegion              String?
  stripeCustomerId        String?                 @unique
  tier                    String?                 @default("free")
  status                  String                  @default("active")
  themeDynamic            Boolean                 @default(true)
  animationsEnabled       Boolean                 @default(true)
  language                String                  @default("fr")
  isPublic                Boolean                 @default(true)
  pushNotifications       Boolean                 @default(true)
  emailNewsletter         Boolean                 @default(false)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  lastCheckedAt           DateTime?
  lastMatchIdSeen         String?
  profileAggregateVersion String?
  accounts                Account[]
  matches                 Match[]
  profileCoachingReports  ProfileCoachingReport[]
  sessions                Session[]
  subscription            Subscription?
  usage                   Usage?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Match {
  id              String           @id @default(cuid())
  matchId         String
  userId          String
  gameCreation    DateTime
  gameDuration    Int
  queueId         Int
  win             Boolean
  championId      Int
  role            String?
  matchJson       Json?
  timelineJson    Json?
  createdAt       DateTime         @default(now())
  hasMatchJson    Boolean          @default(false)
  hasTimelineJson Boolean          @default(false)
  coachingReports CoachingReport[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
  @@index([userId, gameCreation])
}

model CoachingReport {
  id         String   @id @default(cuid())
  matchDbId  String
  version    String   @default("v1")
  quality    String
  reportJson Json
  modelUsed  String?
  createdAt  DateTime @default(now())
  match      Match    @relation(fields: [matchDbId], references: [id], onDelete: Cascade)

  @@unique([matchDbId, version, quality])
}

model Usage {
  id             String    @id @default(cuid())
  userId         String    @unique
  coachingCount  Int       @default(0)
  monthlyCount   Int       @default(0)
  monthlyResetAt DateTime  @default(now())
  lastCoachingAt DateTime?
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                String    @id @default(cuid())
  userId            String    @unique
  status            String
  plan              String
  priceId           String?
  currentPeriodEnd  DateTime?
  cancelAtPeriodEnd Boolean   @default(false)
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProfileCoachingReport {
  id                 String   @id @default(cuid())
  userId             String
  matchesFingerprint String
  version            String   @default("v1")
  quality            String
  reportJson         Json
  modelUsed          String?
  createdAt          DateTime @default(now())
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, matchesFingerprint, version])
  @@index([userId, matchesFingerprint])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
